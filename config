ngx_addon_name=ngx_http_cache_turbo_module

CACHE_TURBO_SRCS="                                                       \
                  $ngx_addon_dir/src/ngx_http_cache_turbo_module.c      \
                  $ngx_addon_dir/src/ngx_http_cache_turbo_shm.c         \
                  $ngx_addon_dir/src/ngx_http_cache_turbo_swr.c         \
                  $ngx_addon_dir/src/ngx_http_cache_turbo_autotune.c    \
                  $ngx_addon_dir/src/ngx_http_cache_turbo_redis.c       \
                  $ngx_addon_dir/src/ngx_http_cache_turbo_memcached.c   \
                  "

CACHE_TURBO_DEPS="                                                      \
                  $ngx_addon_dir/src/ngx_http_cache_turbo_module.h      \
                  "

# This module captures the upstream response body, so it depends on the
# postpone filter being activated (same requirement as srcache).
if [ ! -z "$HTTP_POSTPONE" ]; then
    if [ -z "$HTTP_POSTPONE_FILTER_MODULE" ]; then
        HTTP_POSTPONE_FILTER_MODULE=ngx_http_postpone_filter_module
        HTTP_POSTPONE_FILTER_SRCS=src/http/ngx_http_postpone_filter_module.c
    fi
    if [ "$HTTP_POSTPONE" != YES ]; then
        HTTP_FILTER_MODULES="$HTTP_FILTER_MODULES $HTTP_POSTPONE_FILTER_MODULE"
        HTTP_SRCS="$HTTP_SRCS $HTTP_POSTPONE_FILTER_SRCS"
        HTTP_POSTPONE=YES
    fi
fi

if [ -n "$ngx_module_link" ]; then
    ngx_module_type=HTTP_AUX_FILTER
    ngx_module_name=$ngx_addon_name
    ngx_module_srcs="$CACHE_TURBO_SRCS"
    ngx_module_deps="$CACHE_TURBO_DEPS"
    # Filter ordering. ngx_module_order lists the modules our filter must run
    # ABOVE (earlier on the output path / higher in the chain) — the same
    # convention the gzip/zstd/brotli filters use to sit above copy.
    #
    # We MUST run above the compression filters (gzip/zstd/brotli) so our body
    # filter captures the IDENTITY response body, not the already-compressed
    # bytes. Capturing below them stores a coding-specific body plus a
    # Content-Encoding header and replays e.g. a zstd body to a gzip/identity
    # client on a HIT (browser "Content Encoding Error" — 2026-06-13 incident).
    # Capturing identity instead lets the downstream compression filter
    # re-encode per client on both MISS and HIT, so Vary: Accept-Encoding is a
    # non-issue (one identity copy, correct coding for everyone) — exactly how
    # nginx proxy_cache behaves. headers_filter / copy_filter stay so our body
    # filter still sees the buffers before the copy filter, as before.
    #
    # gzip is static (always present); zstd/brotli are dynamic and named here so
    # the dynamic loader gets an explicit "cache_turbo above them" edge instead
    # of leaving the relative order to load_module sequence. A named module that
    # is not built/loaded is simply ignored.
    ngx_module_order="$ngx_module_name \
                      ngx_http_zstd_filter_module \
                      ngx_http_brotli_filter_module \
                      ngx_http_gzip_filter_module \
                      ngx_http_headers_filter_module \
                      ngx_http_copy_filter_module"
    . auto/module
else
    HTTP_AUX_FILTER_MODULES="$HTTP_AUX_FILTER_MODULES $ngx_addon_name"
    NGX_ADDON_SRCS="$NGX_ADDON_SRCS $CACHE_TURBO_SRCS"
    NGX_ADDON_DEPS="$NGX_ADDON_DEPS $CACHE_TURBO_DEPS"
fi
